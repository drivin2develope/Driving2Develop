# --- Database ---------------------------------------------------------------
# Local dev (default): SQLite file, no setup required.
DATABASE_URL="file:./dev.db"
#
# Production: a real Postgres connection string. Recommended providers:
# Vercel Postgres or Neon (https://neon.tech). Format:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
#
# NOTE: switching to Postgres also requires changing `provider = "sqlite"` to
# `provider = "postgresql"` in prisma/schema.prisma - see README.md.

# --- Auth --------------------------------------------------------------------
# Secret used to sign session JWTs. Use a long, random string in production.
# Generate one with: openssl rand -base64 32
JWT_SECRET="dev-secret-change-me-in-production-please-use-a-long-random-string"

# --- Optional: upgrades upload transcription ---------------------------------
# If set, uploaded recordings are transcribed via OpenAI Whisper and unlock
# transcript-based coaching (filler words, keyword adherence, closing
# strength). Without it, uploads still work but fall back to acoustic-only
# metrics (duration, pauses, volume) - see lib/stt.ts.
# OPENAI_API_KEY="sk-..."
